                    "$ID": {
                        "$ref": "#/definitions/GUID"
                    },
                    "$Type": {
                        "type": "string",
                        "enum": [
                            "DomainModels$Entity"
                        ]
                    },
                    "name": {
                        "type": "string"
                    },
                    "dataStorageGuid": {
                        "$ref": "#/definitions/GUID"
                    },
                    "location": {
                        "$ref": "#/definitions/Location"
                    },
                    "documentation": {
                        "type": "string"
                    },
                    "generalization": {
                        "$ref": "#/definitions/Generalization"
                    },
                    "attributes": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "$ID": {
                                    "$ref": "#/definitions/GUID"
                                },
                                "$Type": {
                                    "type": "string",
                                    "enum": [
                                        "DomainModels$Attribute"
                                    ]
                                },
                                "name": {
                                    "type": "string"
                                },
                                "dataStorageGuid": {
                                    "$ref": "#/definitions/GUID"
                                },
                                "type": {
                                    "$ref": "#/definitions/AttributeType"
                                },
                                "documentation": {
                                    "type": "string"
                                },
                                "value": {
                                    "$ref": "#/definitions/Value"
                                },
                                "exportLevel": {
                                    "type": "string",
                                    "enum": [
                                        "Hidden"
                                    ]
                                }
                            },
                            "required": [
                                "$ID",
                                "$Type",
                                "name",
                                "dataStorageGuid",
                                "type",
                                "documentation",
                                "value",
                                "exportLevel"
                            ]
                        }
                    },
                    "validationRules": {
                        "type": "array",
                        "items": []
                    },
                    "eventHandlers": {
                        "type": "array",
                        "items": []
                    },
                    "indexes": {
                        "type": "array",
                        "items": []
                    },
                    "accessRules": {
                        "type": "array",
                        "items": []
                    },
                    "image": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "imageData": {
                        "type": "string"
                    },
                    "source": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "exportLevel": {
                        "type": "string",
                        "enum": [
                            "Hidden"
                        ]
                    }
                },
                "required": [
                    "$ID",
                    "$Type",
                    "name",
                    "dataStorageGuid",
                    "location",
                    "documentation",
                    "generalization",
                    "attributes",
                    "validationRules",
                    "eventHandlers",
                    "indexes",
                    "accessRules",
                    "image",
                    "imageData",
                    "source",
                    "exportLevel"
                ]
            }
