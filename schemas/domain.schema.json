{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "GUID": {
            "type": "string",
            "format": "uuid"
        },
        "Location": {
            "type": "object",
            "properties": {
                "x": {
                    "type": "integer"
                },
                "y": {
                    "type": "integer"
                }
            },
            "required": [
                "x",
                "y"
            ]
        },
        "EntityAttribute": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "$Type": {
                    "type": "string",
                    "enum": [
                        "DomainModels$Attribute"
                    ]
                },
                "name": {
                    "type": "string"
                },
                "dataStorageGuid": {
                    "$ref": "#/definitions/GUID"
                },
                "type": {
                    "$ref": "#/definitions/AttributeType"
                },
                "documentation": {
                    "type": "string"
                },
                "value": {
                    "$ref": "#/definitions/Value"
                },
                "exportLevel": {
                    "type": "string",
                    "enum": [
                        "Hidden"
                    ]
                }
            },
            "required": [
                "$ID",
                "$Type",
                "name",
                "dataStorageGuid",
                "type",
                "documentation",
                "value",
                "exportLevel"
            ]
        },
        "AttributeType": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "$Type": {
                    "type": "string",
                    "description": "Type of object, should be one of the allowed values.",
                    "enum": [
                        "DomainModels$DateTimeAttributeType",
                        "DomainModels$StringAttributeType",
                        "DomainModels$IntegerAttributeType",
                        "DomainModels$BooleanAttributeType",
                        "DomainModels$EnumerationAttributeType",
                        "DomainModels$DecimalAttributeType",
                        "DomainModels$LongAttributeType",
                        "DomainModels$HashedStringAttributeType",
                        "DomainModels$AutoNumberAttributeType",
                        "DomainModels$BinaryAttributeType"
                    ]
                },
                "length": {
                    "type": "integer"
                }
            },
            "required": [
                "$ID",
                "$Type"
            ]
        },
        "Value": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "$Type": {
                    "type": "string",
                    "description": "Type of object, should be one of the allowed values.",
                    "enum": [
                        "DomainModels$StoredValue"
                    ]
                },
                "defaultValue": {
                    "type": "string"
                }
            },
            "required": [
                "$ID",
                "$Type"
            ]
        },
        "Generalization": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "hasChangedDate": {
                    "type": "boolean"
                },
                "hasCreatedDate": {
                    "type": "boolean"
                },
                "hasOwner": {
                    "type": "boolean"
                },
                "hasChangedBy": {
                    "type": "boolean"
                },
                "persistable": {
                    "type": "boolean"
                },
                "generalization": {
                    "type": "string",
                    "description": "Name of the generalization entity name",
                    "examples": [
                        "System.User"
                    ]
                }
            },
            "required": [
                "$ID",
                "$Type"
            ]
        }
    },
    "type": "object",
    "properties": {
        "$ID": {
            "$ref": "#/definitions/GUID",
            "description": "Unique identifier of the domain object",
            "examples": [
                "3e2e6b3a-4c6f-4c5f-8f4e-2e6b3a4c6f4c"
            ]
        },
        "$Type": {
            "type": "string",
            "enum": [
                "DomainModels$DomainModel"
            ]
        },
        "documentation": {
            "type": "string"
        },
        "entities": {
            "type": "array",
            "items": {
                "type": "object",
                "description": "Domain entity",
                "properties": {
                    "$ID": {
                        "$ref": "#/definitions/GUID"
                    },
                    "$Type": {
                        "type": "string",
                        "enum": [
                            "DomainModels$Entity"
                        ]
                    },
                    "name": {
                        "type": "string"
                    },
                    "dataStorageGuid": {
                        "$ref": "#/definitions/GUID"
                    },
                    "location": {
                        "$ref": "#/definitions/Location"
                    },
                    "documentation": {
                        "type": "string"
                    },
                    "generalization": {
                        "$ref": "#/definitions/Generalization"
                    },
                    "attributes": {
                        "type": "array",
                        "items": {
                            "$ref": "#/definitions/EntityAttribute"
                        }
                    },
                    "validationRules": {
                        "type": "array",
                        "items": []
                    },
                    "eventHandlers": {
                        "type": "array",
                        "items": []
                    },
                    "indexes": {
                        "type": "array",
                        "items": []
                    },
                    "accessRules": {
                        "type": "array",
                        "items": []
                    },
                    "image": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "imageData": {
                        "type": "string"
                    },
                    "source": {
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "exportLevel": {
                        "type": "string",
                        "enum": [
                            "Hidden"
                        ]
                    }
                },
                "required": [
                    "$ID",
                    "$Type",
                    "name",
                    "dataStorageGuid",
                    "location",
                    "documentation",
                    "generalization",
                    "attributes",
                    "validationRules",
                    "eventHandlers",
                    "indexes",
                    "accessRules",
                    "image",
                    "imageData",
                    "source",
                    "exportLevel"
                ]
            }
        },
        "annotations": {
            "type": "array",
            "items": {}
        },
        "associations": {
            "type": "array",
            "items": {}
        },
        "crossAssociations": {
            "type": "array",
            "items": {}
        }
    },
    "required": [
        "$ID",
        "$Type",
        "documentation",
        "entities",
        "annotations",
        "associations",
        "crossAssociations"
    ]
}