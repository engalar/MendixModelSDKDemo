            "type": "array",
            "items": {}
        },
        "associations": {
            "type": "array",
            "items": {}
        },
        "crossAssociations": {
            "type": "array",
            "items": {}
        }
    },
    "required": [
        "$ID",
        "$Type",
        "documentation",
        "entities",
        "annotations",
        "associations",
        "crossAssociations"
    ]
}