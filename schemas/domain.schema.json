{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "GUID": {
            "type": "string",
            "format": "uuid"
        },
        "Location": {
            "type": "object",
            "properties": {
                "x": {
                    "type": "integer"
                },
                "y": {
                    "type": "integer"
                }
            },
            "required": [
                "x",
                "y"
            ]
        },
        "AttributeType": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "length": {
                    "type": "integer"
                }
            },
            "required": [
                "$ID",
                "$Type"
            ]
        },
        "Value": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "defaultValue": {
                    "type": "string"
                }
            },
            "required": [
                "$ID",
                "$Type"
            ]
        },
        "Generalization": {
            "type": "object",
            "properties": {
                "$ID": {
                    "$ref": "#/definitions/GUID"
                },
                "hasChangedDate": {
                    "type": "boolean"
                },
                "hasCreatedDate": {
                    "type": "boolean"
                },
                "hasOwner": {
                    "type": "boolean"
                },
                "hasChangedBy": {
                    "type": "boolean"
                },
                "persistable": {
                    "type": "boolean"
                }
            },
            "required": [
                "$ID",
                "$Type",
                "hasChangedDate",
                "hasCreatedDate",
                "hasOwner",
                "hasChangedBy",
                "persistable"
            ]
        }
    },
    "type": "object",
    "properties": {
