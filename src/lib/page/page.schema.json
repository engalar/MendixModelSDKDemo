{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "page": {
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "canvasWidth": { "type": "integer" },
                "title": {
                    "type": "object",
                    "properties": {
                        "languageCode": { "type": "string" },
                        "text": { "type": "string" }
                    },
                    "required": ["languageCode", "text"]
                },
                "layout": {
                    "type": "object",
                    "properties": {
                        "name": { "type": "string" },
                        "arguments": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "parameter": { "type": "string" },
                                    "widgets": {
                                        "type": "array",
                                        "items": {
                                            "$ref": "#/definitions/widget"
                                        }
                                    }
                                },
                                "required": ["parameter", "widgets"]
                            }
                        }
                    },
                    "required": ["name", "arguments"]
                },
                "allowedRoles": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            },
            "required": [
                "name",
                "canvasWidth",
                "title",
                "layout",
                "allowedRoles"
            ]
        }
    },
    "required": ["page"],
    "definitions": {
        "widget": {
            "type": "object",
            "properties": {
                "type": { "type": "string" },
                "name": { "type": "string" },
                "appearance": {
                    "type": "object",
                    "properties": {
                        "class": { "type": "string" },
                        "designProperties": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "key": { "type": "string" },
                                    "value": { "type": "string" }
                                },
                                "required": ["key", "value"]
                            }
                        }
                    }
                },
                "content": {
                    "type": "object",
                    "properties": {
                        "translations": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "languageCode": { "type": "string" },
                                    "text": { "type": "string" }
                                },
                                "required": ["languageCode", "text"]
                            }
                        }
                    }
                },
                "renderMode": { "type": "string" }
            },
            "required": ["type", "name"]
        }
    }
}
